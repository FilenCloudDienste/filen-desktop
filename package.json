{
	"name": "@filen/desktop",
	"version": "3.0.50",
	"buildNumber": 350,
	"desktopName": "Filen.desktop",
	"description": "Filen Desktop Client",
	"author": "Filen Cloud Dienste UG (haftungsbeschränkt) <support@filen.io>",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"private": false,
	"scripts": {
		"lint": "eslint src",
		"emitTypes": "tsc --emitDeclarationOnly",
		"tsc": "tsc --build",
		"clear": "rimraf ./dist && rimraf ./prod",
		"verify:versions": "node build/rclone/check-versions.mjs",
		"build": "npm run clear && npm run verify:versions && npm run lint && npm run tsc",
		"dev": "npm run build && cross-env NODE_ENV=development electron ./src/index.dev.js --no-sandbox",
		"dev:dev": "tsx ./dev/index.ts",
		"dev:yalc": "npm run yalc && cross-env NODE_ENV=development electron ./src/index.dev.js --no-sandbox",
		"yalc": "npm run build && yalc push",
		"build:mac": "npm run build && electron-builder -m --publish never && node build/inject-min-darwin.js",
		"build:win": "npm run build && electron-builder -w --publish never",
		"build:linux": "npm run build && electron-builder -l --publish never",
		"build:hashes": "tsx ./build/hashes.js",
		"install:filen": "npm install @filen/web@latest @filen/sdk@latest @filen/sync@latest",
		"ncu": "ncu --interactive --format group"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/FilenCloudDienste/filen-desktop.git"
	},
	"keywords": [
		"filen"
	],
	"engines": {
		"node": ">=20"
	},
	"license": "AGPLv3",
	"bugs": {
		"url": "https://github.com/FilenCloudDienste/filen-desktop/issues"
	},
	"homepage": "https://filen.io",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/fs-extra": "^11.0.4",
		"@types/mime-types": "^2.1.4",
		"@types/uuid": "^10.0.0",
		"@types/write-file-atomic": "^4.0.3",
		"cross-env": "^7.0.3",
		"dotenv": "^16.4.5",
		"electron": "^43.0.0",
		"electron-builder": "^26.15.5",
		"eslint": "^9.39.4",
		"globals": "^17.7.0",
		"npm-check-updates": "^22.2.7",
		"rimraf": "^6.0.1",
		"ts-node": "^10.9.2",
		"tsx": "^4.19.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.62.0",
		"yaml": "^2.6.0"
	},
	"dependencies": {
		"@filen/sdk": "^0.4.2",
		"@filen/sync": "^0.3.5",
		"@filen/web": "^0.2.3",
		"axios": "^0.28.1",
		"cors": "^2.8.5",
		"electron-updater": "^6.8.9",
		"express": "^4.19.2",
		"extract-zip": "^2.0.1",
		"fast-glob": "^3.3.2",
		"fs-extra": "^11.2.0",
		"mime-types": "^2.1.35",
		"pino": "^9.5.0",
		"rotating-file-stream": "^3.2.5",
		"selfsigned": "^5.5.0",
		"uuid": "^11.0.3",
		"write-file-atomic": "^6.0.0",
		"zip-a-folder": "^3.1.8"
	},
	"build": {
		"appId": "io.filen.desktop",
		"productName": "Filen",
		"asar": true,
		"npmRebuild": false,
		"nodeGypRebuild": false,
		"artifactName": "Filen_${os}_${arch}.${ext}",
		"afterPack": "build/afterPack.js",
		"afterAllArtifactBuild": "build/notarize-dmg.js",
		"directories": {
			"output": "prod",
			"buildResources": "build"
		},
		"files": [
			"node_modules/**/*",
			"package.json",
			"assets/**/*",
			"dist/**/*",
			"bin/**/*",
			"!bin/deps/**",
			"build/installer.nsh",
			"public/**/*"
		],
		"asarUnpack": [
			"**/*.node",
			"bin/rclone/**"
		],
		"publish": [
			{
				"provider": "generic",
				"url": "https://cdn.filen.io/@filen/desktop/release/latest/"
			}
		],
		"extraFiles": [
			{
				"from": "public/launcher.html",
				"to": "resources/public/launcher.html"
			},
			{
				"from": "public/dark_logo.svg",
				"to": "resources/public/dark_logo.svg"
			},
			{
				"from": "public/light_logo.svg",
				"to": "resources/public/light_logo.svg"
			}
		],
		"win": {
			"azureSignOptions": {
				"publisherName": "Filen Cloud Dienste UG (haftungsbeschränkt)",
				"endpoint": "https://weu.codesigning.azure.net",
				"codeSigningAccountName": "filen-signing",
				"certificateProfileName": "filen-signing",
				"timestampRfc3161": "http://timestamp.acs.microsoft.com",
				"timestampDigest": "SHA256",
				"fileDigest": "SHA256"
			},
			"verifyUpdateCodeSignature": false,
			"icon": "build/icons/win/icon.ico",
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64",
						"arm64"
					]
				},
				{
					"target": "zip",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"publish": [
				{
					"provider": "generic",
					"url": "https://cdn.filen.io/@filen/desktop/release/latest/"
				}
			],
			"extraFiles": [
				{
					"from": "build/installer.nsh",
					"to": "build/installer.nsh"
				}
			],
			"extraResources": [
				{
					"from": "bin/deps",
					"to": "deps",
					"filter": [
						"*.msi"
					]
				}
			]
		},
		"nsis": {
			"oneClick": false,
			"deleteAppDataOnUninstall": true,
			"allowToChangeInstallationDirectory": false,
			"allowElevation": true,
			"runAfterFinish": true,
			"packElevateHelper": true,
			"perMachine": true,
			"selectPerMachineByDefault": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"include": "build/installer.nsh"
		},
		"linux": {
			"executableName": "Filen",
			"syncDesktopName": true,
			"maintainer": "Filen Cloud Dienste UG (haftungsbeschränkt)",
			"vendor": "Filen Cloud Dienste UG (haftungsbeschränkt)",
			"category": "Utility",
			"icon": "build/icons/png/",
			"description": "Filen Desktop Client",
			"synopsis": "Filen Desktop Client",
			"target": [
				{
					"target": "deb",
					"arch": [
						"x64",
						"arm64"
					]
				},
				{
					"target": "rpm",
					"arch": [
						"x64",
						"arm64"
					]
				},
				{
					"target": "zip",
					"arch": [
						"x64",
						"arm64"
					]
				},
				{
					"target": "AppImage",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"publish": [
				{
					"provider": "generic",
					"url": "https://cdn.filen.io/@filen/desktop/release/latest/"
				}
			]
		},
		"mac": {
			"notarize": true,
			"minimumSystemVersion": "12.0",
			"hardenedRuntime": true,
			"gatekeeperAssess": false,
			"entitlements": "build/entitlements.mac.plist",
			"entitlementsInherit": "build/entitlements.mac.plist",
			"category": "public.app-category.productivity",
			"darkModeSupport": true,
			"target": [
				{
					"target": "dmg",
					"arch": [
						"x64",
						"arm64"
					]
				},
				{
					"target": "zip",
					"arch": [
						"x64",
						"arm64"
					]
				}
			],
			"publish": [
				{
					"provider": "generic",
					"url": "https://cdn.filen.io/@filen/desktop/release/latest/"
				}
			],
			"icon": "build/icons/mac/icon.icon",
			"extraResources": [
				{
					"from": "bin/deps",
					"to": "deps",
					"filter": [
						"*.pkg"
					]
				}
			]
		},
		"dmg": {
			"sign": false
		},
		"toolsets": {
			"appimage": "1.0.3"
		}
	}
}
